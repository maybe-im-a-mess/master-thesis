  author = {Nagar, Aishik and Schlegel, Viktor and Nguyen, Thanh-Tung and Li, Hao and Wu, Yuping and Binici, Kuluhan and Winkler, Stefan},
  editor = {Drozd, Aleksandr and Sedoc, Jo{\~a}o and Tafreshi, Shabnam and Akula, Arjun and Shu, Raphael},
